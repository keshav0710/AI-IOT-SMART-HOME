### App Component with Providers

**File**: [src/App.tsx](file:///e:/PROJECTS/clg%20project/IOT%20NEW/src/App.tsx)

```typescript
const queryClient = new QueryClient();

const App = () => (
  <QueryClientProvider client={queryClient}>
    <ThemeProvider>
      <TooltipProvider>
        <Toaster />
        <Sonner />
        <BrowserRouter>
          <Routes>
            <Route path="/" element={<Login />} />
