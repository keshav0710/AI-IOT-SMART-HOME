## 9. State Management & Data Flow

### Data Flow Diagram

```mermaid
sequenceDiagram
    participant ESP32
    participant Firebase
    participant React
    participant User

    ESP32->>Firebase: Push sensor data (every 2s)
    React->>Firebase: Subscribe to /sensors
    Firebase-->>React: Real-time update
    React->>React: Update state via hooks
    React->>User: Re-render UI

    User->>React: Toggle relay switch
    React->>Firebase: Update /relays/relay1
    Firebase-->>ESP32: Push relay command
    ESP32->>ESP32: Toggle physical relay
    Firebase-->>React: Confirm state change
    React->>User: Update UI
```

### Hook Composition in Dashboard

**File**: [src/pages/Dashboard.tsx](file:///e:/PROJECTS/clg%20project/IOT%20NEW/src/pages/Dashboard.tsx)

```typescript
const Dashboard: React.FC = () => {
    // Authentication
    const { user, loading, logout } = useAuth();
    
    // Sensor data (real-time from Firebase)
    const { sensorData, connectionStatus } = useSensorData(user?.uid || null);
    
    // Relay control
    const { relayStates, toggleRelay } = useRelayControl(user?.uid || null);
    
    // Timer management
    const { activeTimers, remainingTimes, setTimer, cancelTimer } = useRelayTimers(user?.uid || null);
    
    // Chatbot
    const { messages, isTyping, sendMessage } = useChatbot(user?.uid || null);
    
    // User settings
    const { settings } = useSettings(user?.uid || null);

    // Motion automation hook
    useMotionAutomation({
        sensorData,
        motionSensorEnabled: settings.sensors.motionSensorEnabled,
        motionAutoEnabled: settings.automation?.motionLightsEnabled ?? true,
        autoOffMinutes: settings.automation?.motionAutoOffMinutes ?? 5,
        holidayMode: settings.automation?.holidayMode ?? false,
    });

    // ... render dashboard
};
```

**Hook dependency chain:**
1. [useAuth](file:///e:/PROJECTS/clg%20project/IOT%20NEW/src/hooks/useAuth.ts#11-39) → Provides `userId`
2. All other hooks depend on `userId`
3. [useMotionAutomation](file:///e:/PROJECTS/clg%20project/IOT%20NEW/src/hooks/useMotionAutomation.ts#19-108) depends on `sensorData` and `settings`

